# Copy this to .env and fill in your values

# PostgreSQL connection string
# Local:  postgresql://postgres:password@localhost:5432/coursereg
# Render: get this from your Render PostgreSQL dashboard
DATABASE_URL="postgresql://postgres:password@localhost:5432/coursereg"

# JWT secret — use any long random string
JWT_SECRET="change_this_to_a_long_random_secret_string_123456"

# JWT expiry
JWT_EXPIRES_IN="7d"

# Port
PORT=5000

# Frontend URL (for CORS)
# Local:  http://localhost:5173
# Deployed: https://your-frontend.vercel.app
CLIENT_URL="http://localhost:5173"
