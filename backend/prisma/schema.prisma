generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  student
  adviser
  hod
  schoolofficer
  academicplanning
  registry
  admin
}

enum RegistrationStatus {
  submitted
  adviser_approved
  hod_approved
  officer_approved
  academic_approved
  approved
  rejected
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  role       Role     @default(student)
  matric     String?  @unique
  department String?
  faculty    String?
  level      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  registrations Registration[]
}

model Course {
  id         String   @id @default(cuid())
  code       String   @unique
  title      String
  units      Int
  level      String
  department String
  semester   String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  registrationCourses RegistrationCourse[]
}

model Registration {
  id          String             @id @default(cuid())
  student     User               @relation(fields: [studentId], references: [id])
  studentId   String
  semester    String
  session     String
  totalUnits  Int
  status      RegistrationStatus @default(submitted)
  submittedAt DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  courses     RegistrationCourse[]
  approvals   Approval[]
}

model RegistrationCourse {
  id             String       @id @default(cuid())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String
  course         Course       @relation(fields: [courseId], references: [id])
  courseId       String
  @@unique([registrationId, courseId])
}

model Approval {
  id             String         @id @default(cuid())
  registration   Registration   @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String
  stage          String
  status         ApprovalStatus @default(pending)
  approverName   String?
  comment        String?
  actedAt        DateTime?
  createdAt      DateTime       @default(now())
  @@unique([registrationId, stage])
}
